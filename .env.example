# NVD API key — get free key at: https://nvd.nist.gov/developers/request-an-api-key
# Without: 4 requests/30s  |  With: 40 requests/30s
NVD_API_KEY=

# Default directory for saved reports (default: current directory)
CVEMAP_OUTPUT_DIR=./reports

# Nmap timing template 0 (paranoid) to 5 (insane)  [default: 3 = normal]
CVEMAP_TIMING=3

# Maximum CVEs to fetch per discovered service  [default: 10]
CVEMAP_MAX_CVES=10

# HTTP request timeout for NVD API in seconds  [default: 30]
CVEMAP_REQUEST_TIMEOUT=30

# Logging level: DEBUG, INFO, WARNING, ERROR  [default: WARNING]
CVEMAP_LOG_LEVEL=WARNING
